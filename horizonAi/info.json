      {
        "name": "server_url",
        "title": "Server URL",
        "type": "text",
        "editable": true,
        "visible": true,
        "required": true,
        "placeholder": "https://api.horizon3ai.com/",
        "value": "https://api.horizon3ai.com/",
        "description": "Horizon.ai GraphQL API endpoint"
      },
      {
        "title": "API Token",
        "type": "password",
        "name": "api_token",
        "required": true,
        "visible": true,
        "editable": true,
        "description": "Bearer token for API authentication"
      },
      {
        "title": "Verify SSL",
        "type": "checkbox",
        "name": "verify_ssl",
        "required": false,
        "visible": true,
        "editable": true,
        "value": true,
        "description": "Verify SSL certificate"
      }
    ]
  },
